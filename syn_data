@dataclass
class Address:
    building_no: str
    street_no: str
    district: str
    city: str
    country: str = "Turkiye"
    
    def to_string(self) -> str:
        
        return f"Sk. {self.street_no}, No: {self.building_no}, {self.district}/{self.city}, {self.country}"


